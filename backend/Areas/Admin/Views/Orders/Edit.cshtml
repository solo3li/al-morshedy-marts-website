@model BackendAPI.Models.Order
@{
    ViewData["Title"] = "تحديث حالة الطلب #" + Model.Id;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-pencil-square"></i> تحديث طلب #@Model.Id</h2>
    <a href="/Admin/Orders" class="btn btn-secondary"><i class="bi bi-arrow-right"></i> عودة للطلبات</a>
</div>

<div class="card shadow-sm max-w-lg mx-auto">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />

            <div class="mb-3">
                <label class="form-label fw-bold">حالة الطلب الحالية</label>
                <input type="text" class="form-control" value="@Model.Status" disabled />
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold">اختر الحالة الجديدة</label>
                <select name="status" class="form-select" required>
                    <!option value="قيد المراجعة" @(Model.Status == "قيد المراجعة" ? "selected" : "")>قيد المراجعة (Pending)</!option>
                    <!option value="قيد التجهيز" @(Model.Status == "قيد التجهيز" ? "selected" : "")>قيد التجهيز (Processing)</!option>
                    <!option value="تم الشحن" @(Model.Status == "تم الشحن" ? "selected" : "")>تم الشحن (Shipped)</!option>
                    <!option value="مكتمل" @(Model.Status == "مكتمل" ? "selected" : "")>مكتمل (Delivered)</!option>
                    <!option value="ملغي" @(Model.Status == "ملغي" ? "selected" : "")>ملغي (Cancelled)</!option>
                </select>
                <div class="form-text text-muted mt-2">تغيير الحالة قد يؤثر على إشعارات العميل أو إيميلات التأكيد.</div>
            </div>

            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-save"></i> حفظ التحديث</button>
        </form>
    </div>
</div>
