@model IEnumerable<BackendAPI.Models.Order>
@{
    ViewData["Title"] = "الطلبات";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-box-seam"></i> إدارة الطلبات</h2>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>رقم الطلب</th>
                        <th>العميل</th>
                        <th>التاريخ</th>
                        <th>الإجمالي</th>
                        <th>الحالة</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">لا توجد طلبات حتى الآن.</td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">#@item.Id</td>
                            <td>
                                @(item.User?.FullName ?? "عميل محذوف") <br/>
                                <small class="text-muted">@item.Phone</small>
                            </td>
                            <td>@item.OrderDate.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="fw-bold text-primary">@item.TotalAmount.ToString("N2") ج.م</td>
                            <td>
                                @if(item.Status == "قيد المراجعة") { <span class="badge bg-warning text-dark">@item.Status</span> }
                                else if(item.Status == "قيد التجهيز") { <span class="badge bg-info text-dark">@item.Status</span> }
                                else if(item.Status == "تم الشحن") { <span class="badge bg-primary">@item.Status</span> }
                                else if(item.Status == "مكتمل") { <span class="badge bg-success">@item.Status</span> }
                                else { <span class="badge bg-danger">@item.Status</span> }
                            </td>
                            <td>
                                <a href="/Admin/Orders/Details/@item.Id" class="btn btn-sm btn-outline-info" title="التفاصيل"><i class="bi bi-eye"></i></a>
                                <a href="/Admin/Orders/Edit/@item.Id" class="btn btn-sm btn-outline-primary" title="تحديث الحالة"><i class="bi bi-pencil"></i></a>
                                
                                <form action="/Admin/Orders/Delete/@item.Id" method="post" class="d-inline" onsubmit="return confirm('هل أنت متأكد من حذف هذا الطلب؟ هذا الإجراء لا يمكن التراجع عنه!');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="حذف"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
