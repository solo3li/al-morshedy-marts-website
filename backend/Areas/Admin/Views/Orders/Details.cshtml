@model BackendAPI.Models.Order
@{
    ViewData["Title"] = "تفاصيل الطلب #" + Model.Id;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-receipt"></i> تفاصيل الطلب #@Model.Id</h2>
    <a href="/Admin/Orders" class="btn btn-secondary"><i class="bi bi-arrow-right"></i> عودة للطلبات</a>
</div>

<div class="row">
    <!-- بيانات الطلب والعميل -->
    <div class="col-md-4 mb-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-light fw-bold">
                <i class="bi bi-person-lines-fill"></i> بيانات العميل والشحن
            </div>
            <div class="card-body">
                <p><strong>اسم العميل:</strong> @(Model.User?.FullName ?? "عميل غير معروف")</p>
                <p><strong>رقم الهاتف:</strong> <a href="tel:@Model.Phone" class="text-decoration-none">@Model.Phone</a></p>
                <p><strong>المدينة:</strong> @Model.City</p>
                <p><strong>عنوان الشحن:</strong> @Model.ShippingAddress</p>
                <p><strong>تاريخ الطلب:</strong> @Model.OrderDate.ToString("yyyy-MM-dd hh:mm tt")</p>
                
                <hr>
                
                <div class="d-flex justify-content-between align-items-center">
                    <strong>حالة الطلب:</strong>
                    @if(Model.Status == "قيد المراجعة") { <span class="badge bg-warning text-dark fs-6">@Model.Status</span> }
                    else if(Model.Status == "مكتمل") { <span class="badge bg-success fs-6">@Model.Status</span> }
                    else if(Model.Status == "ملغي") { <span class="badge bg-danger fs-6">@Model.Status</span> }
                    else { <span class="badge bg-primary fs-6">@Model.Status</span> }
                </div>
                
                @if (!string.IsNullOrEmpty(Model.Notes))
                {
                    <div class="mt-3 alert alert-warning p-2">
                        <strong>ملاحظات المشتري:</strong><br/>
                        @Model.Notes
                    </div>
                }

                <div class="mt-4 text-center">
                    <a href="/Admin/Orders/Edit/@Model.Id" class="btn btn-outline-primary w-100"><i class="bi bi-pencil"></i> تحديث الحالة</a>
                </div>
            </div>
        </div>
    </div>

    <!-- قائمة المنتجات -->
    <div class="col-md-8 mb-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-light fw-bold">
                <i class="bi bi-cart-check"></i> المنتجات المطلوبة
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>المنتج</th>
                                <th>السعر</th>
                                <th>الكمية</th>
                                <th>المجموع</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            @if (item.Product != null)
                                            {
                                                <img src="@item.Product.Image" alt="@item.Product.Name" class="rounded me-2" style="width: 40px; height: 40px; object-fit: cover;">
                                                <span>@item.Product.Name</span>
                                            }
                                            else
                                            {
                                                <span class="text-danger">منتج محذوف (#@item.ProductId)</span>
                                            }
                                        </div>
                                    </td>
                                    <td>@item.Price.ToString("N2") ج.م</td>
                                    <td>x @item.Quantity</td>
                                    <td class="fw-bold">@((item.Price * item.Quantity).ToString("N2")) ج.م</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="3" class="text-end fw-bold">الإجمالي الكلي:</td>
                                <td class="fw-bold text-success fs-5">@Model.TotalAmount.ToString("N2") ج.م</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
