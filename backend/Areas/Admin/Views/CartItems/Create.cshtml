@model BackendAPI.Models.CartItem
@{
    ViewData["Title"] = "إضافة للسلة";
    var products = ViewBag.Products as IEnumerable<BackendAPI.Models.Product>;
    var users = ViewBag.Users as IEnumerable<BackendAPI.Models.ApplicationUser>;
}

<div class="card shadow-sm max-w-2xl mx-auto">
    <div class="card-body">
        <form method="post" action="/Admin/CartItems/Create">
            <div class="mb-3">
                <label class="form-label">المستخدم</label>
                <select name="UserId" class="form-select" required>
                    <option value="">-- اختر المستخدم --</option>
                    @foreach(var u in users!) { <option value="@u.Id">@u.FullName (@u.Email)</option> }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">المنتج</label>
                <select name="ProductId" class="form-select" required>
                    <option value="">-- اختر المنتج --</option>
                    @foreach(var p in products!) { <option value="@p.Id">@p.Name</option> }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">الكمية</label>
                <input type="number" name="Quantity" class="form-control" value="1" required min="1" />
            </div>
            <div class="text-end">
                <a href="/Admin/CartItems" class="btn btn-secondary">إلغاء</a>
                <button type="submit" class="btn btn-primary">حفظ</button>
            </div>
        </form>
    </div>
</div>
