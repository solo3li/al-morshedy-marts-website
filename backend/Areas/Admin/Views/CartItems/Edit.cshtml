@model BackendAPI.Models.CartItem
@{
    ViewData["Title"] = "تعديل السلة";
    var products = ViewBag.Products as IEnumerable<BackendAPI.Models.Product>;
    var users = ViewBag.Users as IEnumerable<BackendAPI.Models.ApplicationUser>;
}

<div class="card shadow-sm max-w-2xl mx-auto">
    <div class="card-body">
        <form method="post" action="/Admin/CartItems/Edit/@Model.Id">
            <input type="hidden" name="Id" value="@Model.Id" />
            <div class="mb-3">
                <label class="form-label">المستخدم</label>
                <select name="UserId" class="form-select" required>
                    @foreach(var u in users!) { 
                        if(u.Id == Model.UserId) { <option value="@u.Id" selected>@u.FullName</option> }
                        else { <option value="@u.Id">@u.FullName</option> }
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">المنتج</label>
                <select name="ProductId" class="form-select" required>
                    @foreach(var p in products!) { 
                        if(p.Id == Model.ProductId) { <option value="@p.Id" selected>@p.Name</option> }
                        else { <option value="@p.Id">@p.Name</option> }
                    }
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">الكمية</label>
                <input type="number" name="Quantity" value="@Model.Quantity" class="form-control" required min="1" />
            </div>
            <div class="text-end">
                <a href="/Admin/CartItems" class="btn btn-secondary">إلغاء</a>
                <button type="submit" class="btn btn-primary">حفظ</button>
            </div>
        </form>
    </div>
</div>
