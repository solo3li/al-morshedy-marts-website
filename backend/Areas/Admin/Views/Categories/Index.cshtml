@model IEnumerable<BackendAPI.Models.Category>
@{
    ViewData["Title"] = "الأقسام";
}

<div class="mb-3 text-end">
    <a href="/Admin/Categories/Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> إضافة قسم جديد</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>الصورة</th>
                <th>الاسم</th>
                <th>الأيقونة</th>
                <th>إجراءات</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var item in Model)
            {
                <tr>
                    <td>
                        <img src="@item.Image" alt="@item.Name" width="50" height="50" class="object-fit-contain bg-white rounded" />
                    </td>
                    <td>@item.Name</td>
                    <td>@item.Icon</td>
                    <td>
                        <a href="/Admin/Categories/Edit/@item.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                        <a href="/Admin/Categories/Delete/@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('هل أنت متأكد من حذف القسم؟')"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
