@model IEnumerable<BackendAPI.Models.Product>
@{
    ViewData["Title"] = "المنتجات";
}

<div class="mb-3 text-end">
    <a href="/Admin/Products/Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> إضافة منتج جديد</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>الصورة</th>
                <th>الاسم</th>
                <th>الماركة</th>
                <th>السعر</th>
                <th>القسم</th>
                <th>إجراءات</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var item in Model)
            {
                <tr>
                    <td>
                        <img src="@item.Image" alt="@item.Name" width="50" height="50" class="object-fit-contain bg-white rounded" />
                    </td>
                    <td>@item.Name</td>
                    <td>@item.Brand</td>
                    <td>@item.Price ج.م</td>
                    <td>@(item.Category?.Name ?? "غير محدد")</td>
                    <td>
                        <a href="/Admin/Products/Edit/@item.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                        <a href="/Admin/Products/Delete/@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('هل أنت متأكد من حذف المنتج؟')"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
