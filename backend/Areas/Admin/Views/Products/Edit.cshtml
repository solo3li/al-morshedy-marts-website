@model BackendAPI.Models.Product
@{
    ViewData["Title"] = "تعديل منتج";
    var categories = ViewBag.Categories as IEnumerable<BackendAPI.Models.Category>;
}

<div class="card shadow-sm max-w-2xl mx-auto">
    <div class="card-body">
        <form method="post" action="/Admin/Products/Edit/@Model.Id">
            <input type="hidden" name="Id" value="@Model.Id" />
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">الاسم</label>
                    <input type="text" name="Name" value="@Model.Name" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">الماركة</label>
                    <input type="text" name="Brand" value="@Model.Brand" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">السعر</label>
                    <input type="number" step="0.01" name="Price" value="@Model.Price" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">السعر القديم (اختياري)</label>
                    <input type="number" step="0.01" name="OldPrice" value="@Model.OldPrice" class="form-control" />
                </div>
                <div class="col-md-12">
                    <label class="form-label">رابط الصورة</label>
                    <input type="url" name="Image" value="@Model.Image" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">القسم</label>
                    <select name="CategoryId" class="form-select" required>
                        <option value="">-- اختر القسم --</option>
                        @foreach(var cat in categories!)
                        {
                            if(cat.Id == Model.CategoryId) {
                                <option value="@cat.Id" selected>@cat.Name</option>
                            } else {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label">شارة (مثال: جديد)</label>
                    <input type="text" name="Badge" value="@Model.Badge" class="form-control" />
                </div>
                <div class="col-12 mt-4 text-end">
                    <a href="/Admin/Products" class="btn btn-secondary">إلغاء</a>
                    <button type="submit" class="btn btn-primary">حفظ التعديلات</button>
                </div>
            </div>
        </form>
    </div>
</div>
