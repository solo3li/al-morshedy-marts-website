@model IEnumerable<BackendAPI.Models.ApplicationUser>
@{
    ViewData["Title"] = "المستخدمين";
}

<div class="mb-3 text-end">
    <a href="/Admin/Users/Create" class="btn btn-primary"><i class="bi bi-person-plus"></i> إضافة مستخدم جديد</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>الاسم الكامل</th>
                <th>الإيميل</th>
                <th>رقم الهاتف</th>
                <th>إجراءات</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var item in Model)
            {
                <tr>
                    <td>@item.FullName</td>
                    <td>@item.Email</td>
                    <td>@item.PhoneNumber</td>
                    <td>
                        <a href="/Admin/Users/Edit/@item.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                        <a href="/Admin/Users/Delete/@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('تأكيد الحذف؟')"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
