@model IEnumerable<BackendAPI.Models.Banner>
@{
    ViewData["Title"] = "البانرات الإعلانية";
}

<div class="mb-3 text-end">
    <a href="/Admin/Banners/Create" class="btn btn-primary"><i class="bi bi-plus-lg"></i> إضافة بانر جديد</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>الصورة</th>
                <th>العنوان</th>
                <th>العنوان الفرعي</th>
                <th>إجراءات</th>
            </tr>
        </thead>
        <tbody>
            @foreach(var item in Model)
            {
                <tr>
                    <td><img src="@item.Image" width="100" class="rounded" /></td>
                    <td>@item.Title</td>
                    <td>@item.Subtitle</td>
                    <td>
                        <a href="/Admin/Banners/Edit/@item.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                        <a href="/Admin/Banners/Delete/@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('تأكيد الحذف؟')"><i class="bi bi-trash"></i></a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
